# ── SalderingsUpdate — Omgevingsvariabelen ───────────────────────────────────
# Kopieer dit bestand naar .env en vul je eigen waarden in.
# Commit .env NOOIT naar Git (staat al in .gitignore).

# ── Tavily (zoeken) ───────────────────────────────────────────────────────────
# Haal je key op via: https://app.tavily.com
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Qwen / Alibaba Cloud DashScope (tekstgeneratie) ──────────────────────────
# Haal je key op via: https://dashscope.console.aliyun.com
# Internationale endpoint (buiten China): https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Gebruikte modellen: qwen-plus, qwen-turbo, qwen-max
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AgentMail (nieuwsbrief versturen) ────────────────────────────────────────
# Registreer via: https://agentmail.to
# INBOX_ID: het ID van je AgentMail-inbox (bijv. "abc123")
# LIST_ID:  het ID van je abonnee-lijst
AGENTMAIL_API_KEY=am_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
AGENTMAIL_INBOX_ID=your-inbox-id
AGENTMAIL_LIST_ID=your-list-id

# ── Site-instellingen ─────────────────────────────────────────────────────────
# Basis-URL van de gepubliceerde site (voor links in nieuwsbrief)
SITE_BASE_URL=https://salderingsupdate.nl
